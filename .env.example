DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# MVP 风格/拼接 LLM 尝试顺序（gemini 与 deepseek 可并存，前者失败再试后者）
MVP_STYLE_LLM_ORDER=gemini,deepseek
# 受控风格词表路径（默认项目内 prompts/mvp_style_vocab.txt）
# MVP_STYLE_VOCAB_PATH=
# 拼接方案说明（默认 prompts/mvp_stitch_prompt.md）
# MVP_STITCH_PROMPT_PATH=
# 商品区内底部留给宣传字块的比例（0~0.45）
# MVP_PROMO_BAND_RATIO=0.2

# --- 可选：Google Gemini ---
# 在 https://aistudio.google.com/apikey 创建密钥；勿提交到 Git
GEMINI_API_KEY=
# 纯文本对话 / 分析用（与绘图模型分开；MVP 受控风格词与拼接方案会按 MVP_STYLE_LLM_ORDER 调用）
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEXT_TIMEOUT_SEC=90
# 原生出图（Nano Banana），仅用于「背景位图」生成；需与 GEMINI_API_KEY 同时配置
# 常用：gemini-2.5-flash-image | gemini-3.1-flash-image-preview | gemini-3-pro-image-preview
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_IMAGE_TIMEOUT_SEC=120
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com

ENV_MODE=development
DEFAULT_CANVAS_SIZE=2048
DEFAULT_SHADOW_OPACITY=120
LOCAL_STORAGE_PATH=./app/static

REVIEW_RULE_WEIGHT=0.65
REVIEW_LLM_WEIGHT=0.35
BACKGROUND_METADATA_PATH=./assets/backgrounds/metadata.json
MAX_UPLOAD_BYTES=10485760
STORAGE_MAX_FILES=500
STORAGE_MAX_AGE_DAYS=7

# --- 可选：Nanobanana（或其它兼容 OpenAI 图生图）背景 API ---
# 填「完整 POST 地址」，例如：https://你的服务域名/v1/images/generations
# 留空则仅用本地渐变 / 素材库背景（不联网画图）
NANOBANANA_API_URL=
NANOBANANA_API_KEY=
# 若对方接口需要 model 字段再填
NANOBANANA_MODEL=
# openai_images（默认，解析 data[0].url / b64_json）| json_url | json_base64
NANOBANANA_RESPONSE_MODE=openai_images
NANOBANANA_TIMEOUT_SEC=120

# --- 可选：Stable Diffusion（Automatic1111 WebUI 或兼容 OpenAI 图接口）---
# 例（本机 WebUI）：STABLE_DIFFUSION_API_URL=http://127.0.0.1:7860/sdapi/v1/txt2img
STABLE_DIFFUSION_API_URL=
STABLE_DIFFUSION_MODE=a1111
# STABLE_DIFFUSION_API_KEY=
STABLE_DIFFUSION_TIMEOUT_SEC=180
SD_STEPS=28
SD_CFG_SCALE=7.0
SD_SAMPLER_NAME=DPM++ 2M Karras
# openai_images 模式时需填对方模型名
# STABLE_DIFFUSION_MODEL=

# 背景位图尝试顺序（逗号分隔）：nanobanana | stable_diffusion | gemini | sd（sd 同 stable_diffusion）
# 若 Gemini 429 或不可用，可把 stable_diffusion 放前面：
# MVP_BACKGROUND_RASTER_ORDER=stable_diffusion,nanobanana,gemini

# 商品图在画框内缩放：contain（默认，不裁切）| cover
# MVP_PRODUCT_IMAGE_FIT=contain
# 商品区相对模板框的内缩比例 0~0.12
# MVP_PRODUCT_BOX_INSET_RATIO=0.03

# --- 可选：PIL 绘制中文标题用字体路径（不填则自动找 Windows 微软雅黑等）---
# CJK_FONT_PATH=C:\\Windows\\Fonts\\msyh.ttc
